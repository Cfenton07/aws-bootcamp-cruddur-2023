[deploy]
bucket = '<your-cfn-artifacts-bucket-name>'
region = '<your-aws-region>'
stack_name = 'CrdFrontend'

[parameters]
NetworkingStack = 'CrdNet'
ClusterStack = 'CrdCluster'
# SHA-pinned image URI (NEVER :latest). Built with REACT_APP_BACKEND_URL=https://api.fentoncruddur.com
EcrImage = '<your-acct-id>.dkr.ecr.<your-region>.amazonaws.com/frontend-react-js:<git-sha>'
ContainerPort = '3000'
Cpu = '256'
Memory = '512'
DesiredCount = '1'
LogRetentionDays = '14'

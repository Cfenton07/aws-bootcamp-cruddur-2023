#!/usr/bin/env python3

import os
import sys
import glob
import re
import time
import importlib

# Add backend-flask to Python path so we can import lib.db
# Script lives at backend-flask/bin/db/rollback
script_dir = os.path.dirname(os.path.abspath(__file__))
backend_dir = os.path.abspath(os.path.join(script_dir, '..', '..'))
sys.path.insert(0, backend_dir)

from lib.db import db

def get_last_successful_run():
  sql = """
    SELECT last_successful_run
    FROM public.schema_information
    WHERE id = 1
  """
  return int(db.query_value(sql, {}, verbose=False))

def set_last_successful_run(value):
  sql = """
    UPDATE public.schema_information
    SET last_successful_run = %(last_successful_run)s
    WHERE id = 1
  """
  db.query_commit(sql, {'last_successful_run': value}, verbose=False)

last_successful_run = get_last_successful_run()

# Add migrations directory to Python path for dynamic imports
migrations_path = os.path.join(backend_dir, 'db', 'migrations')
sys.path.insert(0, migrations_path)

# Find all migration files
migration_files = glob.glob(os.path.join(migrations_path, '*.py'))
migration_files.sort()

# Find the last migration that was run
last_migration_file = None
for migration_file in migration_files:
  filename = os.path.basename(migration_file)
  module_name = os.path.splitext(filename)[0]

  match = re.match(r'^(\d+)_', filename)
  if match:
    file_time = int(match.group(1))
  else:
    continue

  if last_successful_run >= file_time:
    last_migration_file = {
      'filename': filename,
      'module_name': module_name,
      'file_time': file_time
    }

if last_migration_file is None:
  print("No migrations to roll back.")
else:
  print(f"=== Rolling back: {last_migration_file['module_name']} ===")

  mod = importlib.import_module(last_migration_file['module_name'])

  for attr_name in dir(mod):
    if attr_name.endswith('Migration') and attr_name != 'Migration':
      migration_class = getattr(mod, attr_name)
      print(migration_class.rollback_sql())
      migration_class.rollback()
      break

  set_last_successful_run('0')
  print(f"--- Rollback complete: {last_migration_file['module_name']} ---\n")
#! /usr/bin/bash

# ============================================================
# RUN PRODUCTION FRONTEND CONTAINER LOCALLY
# ============================================================
# Runs the production Docker image (not the dev docker-compose one)
# on the cruddur-net network for local testing.
#
# Prerequisites:
#   1. Run bin/frontend/generate-env to create the .env file
#   2. Start docker-compose services
#   3. Build the production image: bin/frontend/build

ABS_PATH=$(readlink -f "$0")
BIN_PATH=$(dirname $ABS_PATH)
PROJECT_PATH=$(dirname $(dirname $BIN_PATH))

ENVFILE_PATH="$PROJECT_PATH/frontend-react-js.env"

if [ ! -f "$ENVFILE_PATH" ]; then
  echo "ERROR: Environment file not found at $ENVFILE_PATH"
  echo "Run bin/frontend/generate-env first."
  exit 1
fi

docker run --rm \
  --env-file "$ENVFILE_PATH" \
  --network cruddur-net \
  --publish 3000:3000 \
  -it \
  frontend-react-js
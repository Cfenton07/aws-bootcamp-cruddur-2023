#! /usr/bin/bash

# ============================================================
# GENERATE FRONTEND ENVIRONMENT FILE
# ============================================================
# Reads frontend-react-js.env.template and substitutes all ${VAR}
# references with their actual values from the current shell.
# Output: frontend-react-js.env (used by docker-compose and docker run)

ABS_PATH=$(readlink -f "$0")
BIN_PATH=$(dirname $ABS_PATH)
PROJECT_PATH=$(dirname $(dirname $BIN_PATH))

TEMPLATE_PATH="$PROJECT_PATH/frontend-react-js.env.template"
OUTPUT_PATH="$PROJECT_PATH/frontend-react-js.env"

echo "== Generate Frontend Environment File =="

if [ ! -f "$TEMPLATE_PATH" ]; then
  echo "ERROR: Template not found at $TEMPLATE_PATH"
  exit 1
fi

envsubst < "$TEMPLATE_PATH" > "$OUTPUT_PATH"

echo "Generated: $OUTPUT_PATH"